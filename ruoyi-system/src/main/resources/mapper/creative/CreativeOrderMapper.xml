<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.creative.CreativeOrderMapper">

    <resultMap id="CreativeOrderResult" type="com.ruoyi.system.domain.creative.CreativeOrder">
        <result property="orderId" column="order_id"/>
        <result property="orderNo" column="order_no"/>
        <result property="buyerId" column="buyer_id"/>
        <result property="sellerId" column="seller_id"/>
        <result property="orderAmount" column="order_amount"/>
        <result property="orderStatus" column="order_status"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectCreativeOrderVo">
        select order_id, order_no, buyer_id, seller_id, order_amount, order_status, create_by, create_time, update_by, update_time, remark
        from creative_custom_order
    </sql>

    <select id="selectCreativeOrderByOrderId" parameterType="Long" resultMap="CreativeOrderResult">
        <include refid="selectCreativeOrderVo"/>
        where order_id = #{orderId}
    </select>

    <select id="selectCreativeOrderList" parameterType="com.ruoyi.system.domain.creative.CreativeOrder" resultMap="CreativeOrderResult">
        <include refid="selectCreativeOrderVo"/>
        <where>
            <if test="orderNo != null and orderNo != ''">and order_no like concat('%', #{orderNo}, '%')</if>
            <if test="orderStatus != null and orderStatus != ''">and order_status = #{orderStatus}</if>
            <if test="buyerId != null">and buyer_id = #{buyerId}</if>
            <if test="sellerId != null">and seller_id = #{sellerId}</if>
        </where>
        order by order_id desc
    </select>

    <insert id="insertCreativeOrder" parameterType="com.ruoyi.system.domain.creative.CreativeOrder" useGeneratedKeys="true" keyProperty="orderId">
        insert into creative_custom_order (order_no, buyer_id, seller_id, order_amount, order_status, remark, create_by, create_time)
        values (#{orderNo}, #{buyerId}, #{sellerId}, #{orderAmount}, #{orderStatus}, #{remark}, #{createBy}, sysdate())
    </insert>

    <update id="updateCreativeOrder" parameterType="com.ruoyi.system.domain.creative.CreativeOrder">
        update creative_custom_order
        <set>
            <if test="orderNo != null">order_no = #{orderNo},</if>
            <if test="buyerId != null">buyer_id = #{buyerId},</if>
            <if test="sellerId != null">seller_id = #{sellerId},</if>
            <if test="orderAmount != null">order_amount = #{orderAmount},</if>
            <if test="orderStatus != null">order_status = #{orderStatus},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_by = #{updateBy},
            update_time = sysdate()
        </set>
        where order_id = #{orderId}
    </update>

    <delete id="deleteCreativeOrderByOrderId" parameterType="Long">
        delete from creative_custom_order where order_id = #{orderId}
    </delete>

    <delete id="deleteCreativeOrderByOrderIds" parameterType="Long">
        delete from creative_custom_order where order_id in
        <foreach collection="array" item="orderId" open="(" separator="," close=")">
            #{orderId}
        </foreach>
    </delete>
</mapper>
